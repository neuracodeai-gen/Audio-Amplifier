{
  "manifest_version": 3,
  "name": "Tab Sound Amplifier & Enhancer",
  "version": "1.1.0",
  "description": "Amplify and enhance audio on the current tab with per-tab controls.",
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Sound Amplifier",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
